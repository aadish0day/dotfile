#!/bin/bash

# Path to your vault on S23
VAULT_DIR="$HOME/storage/documents/Obsidian"

# Check if directory exists
if [ ! -d "$VAULT_DIR" ]; then
    echo "Error: Vault directory not found"
    exit 1
fi

cd "$VAULT_DIR" || exit

echo "Starting Sync..."

# 1. Pull changes from remote
# Using rebase to maintain a linear history
if git pull origin main --rebase; then
    echo "Pull successful"
else
    echo "Pull failed: Check for manual conflicts"
    exit 1
fi

# # 2. Add and Commit
 git add .

 # Only commit if changes exist
 if ! git diff-index --quiet HEAD; then
     echo "Committing local changes..."
     git commit -m "S23 Sync: $(date +'%Y-%m-%d %H:%M')"
 else
     echo "No local changes to commit"
 fi

 # 3. Push to Remote
 if git push origin main; then
     echo "Push successful: All synced"
 else
     echo "Push failed"
     exit 1
 fi
